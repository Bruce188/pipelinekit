{
  "_comment": "Copy to <your-project>/.mcp.json. PIN serena ref (replace @main with a commit SHA) before sandbox use.",
  "_security_note": "git+https without a pinned ref allows upstream takeover to execute arbitrary code via uvx. Replace 'main' with a known-good commit hash.",
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena@main",
        "serena-mcp-server",
        "--project",
        "."
      ]
    }
  },
  "_mobile_instructions": "Optional iOS-development MCPs. Uncomment-and-move into 'mcpServers' to enable. Both require Xcode on host. ios-simulator-mcp uses git+https — PIN the ref (replace @main with a commit SHA) before sandbox use.",
  "_optional_mobile_mcpServers": {
    "XcodeBuildMCP": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "xcodebuildmcp"]
    },
    "ios-simulator-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/joshuayoes/ios-simulator-mcp@main",
        "ios-simulator-mcp"
      ]
    }
  },
  "_claude_context_instructions": "COMMUNITY MCP — @zilliztech/claude-context is maintained by Zilliz (Milvus commercial vendor), NOT Anthropic. Uncomment-and-move into 'mcpServers' to enable codebase semantic RAG (AST-aware chunking + Merkle-tree incremental indexing). LOCAL MODE: set EMBEDDING_PROVIDER=ollama (or transformers) and provide a local embedding model — no Milvus account needed. CLOUD MODE: set MILVUS_ADDRESS and MILVUS_TOKEN to Zilliz Cloud credentials. PIN guidance: replace '-y' with a fixed @version (e.g. @zilliztech/claude-context@0.1.0) for reproducibility. 50k LOC heuristic: /analyze skips semantic retrieval below 50000 LOC; opt-in indexing on smaller repos via direct MCP query.",
  "_optional_claude_context_mcpServers": {
    "claude-context": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@zilliztech/claude-context"],
      "env": {
        "EMBEDDING_PROVIDER": "",
        "MILVUS_ADDRESS": "",
        "MILVUS_TOKEN": ""
      }
    }
  },
  "_agentmemory_instructions": "COMMUNITY MCP / LIBRARY — rohitg00/agentmemory is a community project (NOT Anthropic-official). Opt-in structured-retrieval layer over the existing ~/.claude/memory/<slug>/ flat-file markdown system. Adds semantic similarity, decay, and contextual recall. Complementarity: flat-file remains the canonical write path; agentmemory is a secondary retrieval index — plain-markdown inspectability via cat/Read/grep is preserved. Vendoring skeleton lives under claude/lib/agentmemory/. Mode (same-store vs separate-store) and upstream shape (library vs MCP) are deferred to a follow-up iteration. PIN guidance: when upstream ships an MCP server, replace any rolling ref (e.g. @main) with a fixed commit SHA or pinned version BEFORE sandbox use to prevent supply-chain takeover.",
  "_optional_agentmemory_mcpServers": {
    "agentmemory": {
      "type": "stdio",
      "command": "TBD",
      "args": ["TBD"],
      "env": {
        "AGENTMEMORY_STORE_MODE": "",
        "AGENTMEMORY_DATA_DIR": ""
      }
    }
  }
}
